<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivGuestPhoto"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="#F5F6FA"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#B328C6"
            android:elevation="2dp"
            android:padding="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvOrderCocktailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Neon Sour"
                android:textColor="#3B205E"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOrderGuestName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="For: John D."
                android:textColor="#757575"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnMarkDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#B328C6"
            android:textColor="#FFFFFF"
            android:elevation="4dp"
            android:text="DONE"
            android:textStyle="bold"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>