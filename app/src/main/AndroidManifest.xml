<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BarCode">

        <activity android:name=".ui.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.LiveBartenderActivity"
            android:exported="false" />
        <activity
            android:name=".ui.GuestMenuActivity"
            android:exported="false" />
        <activity
            android:name=".ui.SettingsFragment"
            android:exported="false" />
        <activity
            android:name=".ui.com.example.barcode.ui.AddCocktailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AdminHostActivity"
            android:exported="false" />
        <activity android:name=".auth.SignUpActivity" />
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false">
        </activity>
        <activity
            android:name=".ui.EventDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.NewEventActivity"
            android:exported="false" />
        <activity
            android:name=".ui.CocktailSwipeActivity"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>